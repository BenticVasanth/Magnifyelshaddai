    <script>
        function validatePrayerRain() {
            var title = CKEDITOR.instances['titleEditor'].getData();
            var verses = CKEDITOR.instances['versesEditor'].getData();
            var prayer = CKEDITOR.instances['prayerEditor'].getData();

            if (title != "" && verses != "" && prayer != "") {
                return true;
            }

            if (title == "") {
                $("#errorMessageTitle").css('display', 'block');
                return false;
            }
            else
                $("#errorMessageTitle").css('display', 'none');

            if (verses == "") {
                $("#errorMessageVerses").css('display', 'block');
                return false;
            }
            else
                $("#errorMessageVerses").css('display', 'none');

            if (prayer == "") {
                $("#errorMessagePrayer").css('display', 'block');
                return false;
            }
            else
                $("#errorMessagePrayer").css('display', 'none');
        }

        var UpdateDatabaseFrequently = function () {
            $.ajax({
                url: "@Url.Action("UpdateDatabaseFrequently", "PrayerRain")",
                type: 'POST',
                async: false
                //success: function (data) {
                //    if (data.result == "Success") {
                //        alert('Success');
                //    }
                //    else {
                //        alert('Failure');
                //    }

                //}
            });
        };

        var interval = 1000 * 60 * 1; // where X is your every X minutes
        setInterval(UpdateDatabaseFrequently, interval);
    </script>

