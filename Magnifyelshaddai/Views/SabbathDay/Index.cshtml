@model IEnumerable<Magnifyelshaddai.Models.SabbathDayDocumentVM>

@{
    ViewBag.Title = "Sabbath Day Documents - Magnify El Shaddai";
    var grid = new WebGrid(canPage: true, rowsPerPage: 10);
    grid.Bind(source: Model, rowCount: ViewBag.TotalRows, autoSortAndPage: false);
    //WebGrid grid = new WebGrid(source: Model, canSort: false, canPage: false);
}

@Html.Partial("_SideMenu")

<div class="container_display">
    <h2 class="main-title">Sabbath Day documents</h2>

    <h6 class="quote">"Remember the <strong>SABBATH DAY</strong>, to keep it <strong>HOLY</strong>" <span>(Exodus 20:8)</span></h6>

    <div class="navbar-collapse">
        @using (Html.BeginForm("Index", "SabbathDay", FormMethod.Get, new { @class = "navbar-form navbar-left" }))
        {
            <div class="form-group">
                <input type="text" name="search" value="@ViewBag.search" class="form-control" placeholder="search" />
            </div>
            <button type="submit" value="Search" class="btn">Search</button>
        }

        @if (Session["UserType"].ToString() == "Admin")
        {
            <a href="@Url.Action("UploadSabbathDayDocument", "SabbathDay")">
                <span class="btn addSabbath">Add new</span>
            </a>
        }

        <input type="hidden" value="@Session["UserType"]" id="hdnUserType" />

        <div class="display_body">
            @*@Html.Partial("_SabbathDay", Model.sabbathDayDocument)*@
            <div>
                @grid.GetHtml(
                tableStyle: "table table-bordered",
                htmlAttributes: new { @id = "WebGrid", @class = "Grid" },
                columns: grid.Columns(
                        //grid.Column(null, null, format: @<text><img src="~/Images/plus.png" /><div style="display:none"></div></text>),

                           grid.Column(null, null, format: (item) =>
                          {
                              if (Session["UserType"].ToString() == "Admin" || Session["UserType"].ToString() == "Subadmin")
                                  return Html.Raw(string.Format("<text><img src=\"{0}\"><div style='display:none'></div></text>", Url.Content("~/Images/plus.png")));
                              else
                                  return Html.Raw(string.Format(""));
                          }),
                                            grid.Column(columnName: "sabbathDayDocument.totalDownloadedCount", header: "D.Count"),
                                            grid.Column(columnName: "sabbathDayDocument.Title", header: "Title"),
                                            grid.Column(columnName: "sabbathDayDocument.DocumentReference", header: "Author"),
                                            grid.Column(columnName: "sabbathDayDocument.CreatedDateTime", header: "Date", format: (item) => string.Format("{0:dd-MMM-yyyy}", item.sabbathDayDocument.CreatedDateTime)),
                                            grid.Column("", header: "Download", style: "width:260%", format: @<text>
                                                @Html.ActionLink(" ", "DownloadSabbathDayDocument", "SabbathDay", new { id = item.sabbathDayDocument.IntId }, new { target = "_blank", style = "background: url('/Images/pdf-icon.png') no-repeat;display:block;height: 25px;width: 25px;vertical-align:middle;margin: 0px 0px 0px 30px;background-size: 100% 100%; font-size: 12px;" })
                                            </text>),

                                            grid.Column(format: (item) =>
                                            {
                                                WebGrid subGrid = new WebGrid(source: item.lstSabbathDayDocumentsDownloadDetails, canSort: false, canPage: false);
                                                return subGrid.GetHtml(
                                                    htmlAttributes: new { @class = "ChildGrid" },
                                                    columns: subGrid.Columns(
                                                    subGrid.Column(columnName: "DownloadedBy", header: "Downloaded By")
                                                    ));
                                            })
                                            ))
                <div class="row">
                    <div class="col-sm-6">
                        @grid.PagerList(mode: WebGridPagerModes.All, paginationStyle: "pagination pagination-small pagination-right")
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style type="text/css">
    body {
        font-family: Arial;
        font-size: 10pt;
    }

    .Grid {
        border: 1px solid #ccc;
        border-collapse: collapse;
        background-color: #fff;
    }

        .Grid th {
            background-color: #B8DBFD;
            color: #333;
            font-weight: bold;
        }

        .Grid th, .Grid td {
            padding: 5px;
            border: 1px solid #ccc;
        }

        .Grid img {
            cursor: pointer;
        }

    .ChildGrid {
        width: 100%;
    }

        .ChildGrid th {
            background-color: #3076ce;
            color: #fff;
            font-weight: bold;
        }

        .ChildGrid tbody tr:nth-child(even) {
            background-color: rgb(15 120 220 / 30%) !important;
        }

        .ChildGrid tbody tr td, th {
            padding: 5px 10px;
        }

    table tfoot {
        display: none;
    }

    h6 span {
        font-size: 15px;
        font-weight: bold;
    }

    h6 strong {
        font-size: 24px;
    }
</style>

<script type="text/javascript">
    $(function () {
        var hdnUserType = $('#hdnUserType').val();
        if (hdnUserType != "Admin" && hdnUserType != "Subadmin") {
            $("table tr th:nth-child(1), table tr td:nth-child(1)").css("display", "none");
            $("table tr th:nth-child(2), table tr td:nth-child(2)").css("display", "none");
        }

        //if (hdnUserType != "Admin" && hdnUserType != "Subadmin") {
        //    $('#documentView').removeClass();
        //}
        //else {
        //    $('#documentView').removeClass();
        //}

        //Loop through all Child Grids.
        $("#WebGrid .ChildGrid").each(function () {
            //Copy the Child Grid to DIV.
            var childGrid = $(this).clone();
            $(this).closest("TR").find("TD").eq(0).find("DIV").append(childGrid);

            //Remove the Last Column from the Row.
            $(this).parent().remove();
        });

        //Remove Last Column from Header Row.
        $("#WebGrid TH:last-child").eq(0).remove();
    });
    //Assign Click event to Plus Image.
    $("body").on("click", "img[src*='plus.png']", function () {
        $(this).closest("tr").after("<tr><td></td><td colspan = '999'>" + $(this).next().html() + "</td></tr>");
        $(this).attr("src", "/images/minus.png");
    });
    //Assign Click event to Minus Image.
    $("body").on("click", "img[src*='minus.png']", function () {
        $(this).attr("src", "/images/plus.png");
        $(this).closest("tr").next().remove();
    });
</script>

