@model Magnifyelshaddai.Models.DocumentView
@{
    ViewBag.Title = "Quick Search - Magnify El Shaddai";
}

@Html.Partial("_SideMenu")

<div class="searchAll quickSearch">
    @using (Html.BeginForm("Index", "QuickSearch", FormMethod.Get, new { @class = "navbar-form navbar-right" }))
    {
        <div class="mt50">
            <div class="form-group">
                <input type="text" name="search" value="@ViewBag.search" class="form-control" placeholder="search" />
            </div>
            <button type="submit" value="Search" class="btn">Search</button>
        </div>
    }
</div>

<div class="display_body quickSearch">
    <div class="Grid">
        <div class="title">
            <p>Sabbath Day Documents</p>
        </div>
        <table class="table table-bordered mt10">
            <thead>
            <th>
                Title
            </th>
            <th>
                Author
            </th>
            <th>
                Date
            </th>
            <th>
                Downloads
            </th>
            </thead>
            <tbody>
                @foreach (Magnifyelshaddai.Models.EDMXModel.Document sabbathDayDocuments in ViewBag.lstSabbathDayDocuments)
                {
                    <tr>
                        <td>@sabbathDayDocuments.Title</td>
                        <td>@sabbathDayDocuments.DocumentReference</td>
                        <td>@sabbathDayDocuments.CreatedDateTime.Value.ToString("dd-MMM-yyyy")</td>
                        <td>@Html.ActionLink(" ", "DownloadSabbathDayDocument", "SabbathDay", new { id = sabbathDayDocuments.IntId }, new { target = "_blank", style = "background: url('/Images/pdf-icon.png') no-repeat;display:block;height: 25px;width: 25px;vertical-align:middle;margin: 0px 0px 0px 30px;background-size: 100% 100%; font-size: 12px;" })</td>
                    </tr>
                }

            </tbody>
        </table>
    </div>

