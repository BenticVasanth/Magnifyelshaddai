<style>
    .display_body {
        max-width: 79%;
        float: right;
        margin-right: 5px !important;
        padding-top: 10px;
    }
    /*hr {
        margin-top: 20px;
        margin-bottom: 20px;
        border: 0;
        border-top: 1px solid #a74da2;
        width: auto;
    }*/

    .title p {
        background-color: #a74da2;
        color: #fff;
        font-weight: bold;
        font-size: 25px;
        padding: 5px;
        margin: 0px;
        width: fit-content;
        border: 1px solid #a74da2;
        border-radius: 5px;
    }

    .display_body table tbody tr:nth-child(even) {
        background-color: rgb(48 118 206 / 25%) !important;
    }

    .display_body .btn {
        margin-bottom: 15px;
    }

    .searchAll {
        width: 90%;
        margin: 25px auto 0px auto;
    }

    .table {
        margin-bottom: 0px;
    }

    .Grid {
        border-collapse: collapse;
        background-color: #fff;
        width: 98%;
        margin: auto;
        margin-bottom: 20px;
        padding-bottom: 20px;
        border-bottom: 2px solid #a74da2;
    }

        .Grid:last-child {
            padding-bottom: 0px;
            border-bottom: 0px solid #a74da2;
        }
    
    .Grid th {
            text-align: center;
            background-color: #4a86d1;
            color: #ffffff;
            font-weight: bold;
        }

        .Grid th, .Grid td {
            padding: 5px;
            border: 1px solid #ccc;
        }

        .Grid img {
            cursor: pointer;
        }
</style>
