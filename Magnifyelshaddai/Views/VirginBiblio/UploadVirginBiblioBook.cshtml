@model Magnifyelshaddai.Models.EDMXModel.LibraryIndex 

@{
    Layout = "~/Views/Shared/_VirginBiblioLayout.cshtml";
    ViewBag.Title = "Magnify Elshaddai - Upload Books";
}


@using (Html.BeginForm("UploadVirginBiblioBook", "VirginBiblio", FormMethod.Post, new { enctype = "multipart/form-data" }))
{<div class="container">
        <div class="row">
            <div class="form-group mg_elshaddai_possub"><h2>Upload Books</h2></div>
            <div class="form-group mg_elshaddai_possub">
                @Html.TextBoxFor(model => model.Title, new { @class = "form-control mg_form_control", @placeholder = "Title" })
                @Html.ValidationMessageFor(model => model.Title)
            </div>
            <div class="form-group mg_elshaddai_possub">
                @Html.TextBoxFor(model => model.Author, new { @class = "form-control mg_form_control", @placeholder = "Author" })
                @Html.ValidationMessageFor(model => model.Author)
            </div>
            
            <input class="btn btn-default" type="file" name="UpladBook" />
            <input class="btn btn-primary" type="submit" value="Upload" id="btnid" style="margin-top:20px;"/>
            </div>
    </div>
            }
