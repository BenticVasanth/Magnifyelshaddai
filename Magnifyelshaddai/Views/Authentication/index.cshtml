<style>
    .img-cont img {
        background-position: center;
        background-size: cover;
        background-repeat: no-repeat;
        width: 100%;
        min-height: 80vh;
    }

    .elsaddai_signin .center-img {
        align-items: center;
        display: flex;
        height: 300px;
    }

    .img-cont {
        position: relative;
    }

        .img-cont .h1 {
            position: absolute;
            top: 10%;
            left: 35%;
            transform: translate(-20%, -50%);
            font-weight: 500;
            color: #000;
        }

        .img-cont .con {
            position: absolute;
            top: 50%;
            left: 58%;
            transform: translate(-50%, -50%);
            font-weight: 500;
            color: #000;
        }

    .homepage-prayer {
        width: 100%;
        text-align: center;
        margin-top: 70px;
        background: #ededed;
        padding: 60px 0px;
        margin-right: 0px;
        margin-left: 0px;
    }

        .homepage-prayer b {
            font-weight: 900;
        }

    .g-wrapper {
        border: 1px solid #c8c0c0;
        padding: 15px;
        margin-top: 30px;
        border-radius: 15px;
    }

    .mpr {
        text-align: center;
        margin-top: 40px;
    }

    .con p {
        margin: 0 0 0 0px;
    }

    .modal-header {
        background-color: #4e0249;
        color: #ffffff;
    }

    .modal-body {
        padding: 2rem 3rem;
    }

        .modal-body p {
            font-size: 18px;
            line-height: 30px;
        }

    .btn {
        padding: 5px 10px !important;
    }

    .close {
        position: absolute;
        top: -1rem;
        right: -1rem;
        padding: 2px 6px !important;
        background-color: #fff !important;
        opacity: 1;
        border-radius: 15px;
    }

    .modal-content {
        margin-top: 3rem;
        width: 100%;
    }

    .modal-body.registarion-instrct {
        padding: 15px;
    }

    .backShadow {
        box-shadow: rgb(0 0 0 / 15%) 0px 2px 8px;
        border-radius: 5px;
    }

    img.img-fluid.backShadow {
        max-width: 100%;
        height: auto;
    }

    .modal-body.banner {
        padding: 0px !important;
    }

        .modal-body.banner img.img-fluid.backShadow {
            max-width: 100%;
            height: auto;
            width: 100%;
        }

    a {
        text-decoration: none;
        color: #9ca0b1;
    }

    .wrapper {
        text-align: center;
        cursor: pointer;
        width: fit-content;
        margin: 1rem auto 0;
    }

        .wrapper h1, .wrapper h3 {
            color: #fff;
            text-transform: uppercase;
            font-weight: 700;
            font-family: "Comic Sans MS, Comic Sans", cursive;
            background: linear-gradient(90deg, rgba(6,150,250,1) 0%, rgba(9,9,121,1) 30%, rgba(9,9,121,1) 70%, rgba(6,150,250,1) 100%);
            background-size: auto auto;
            background-clip: border-box;
            background-size: 200% auto;
            color: #fff;
            background-clip: text;
            text-fill-color: transparent;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: textclip 1.5s linear infinite;
            display: inline-block;
        }

            .wrapper h1 span {
                vertical-align: top;
                font-weight: 400;
                font-size: 0.5em;
            }

    @@keyframes textclip {
        to {
            background-position: 200% center;
        }
    }

    .hyperLink {
        color: #000000;
    }

        .hyperLink:hover, .hyperLink:focus {
            text-decoration: none;
            color: red;
        }
</style>

