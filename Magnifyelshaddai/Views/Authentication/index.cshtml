        <div class="wrapper" title="7th Bible Workshop Online Registration Click Here" onclick="googleFormLink()">
            <h1>7<span class="supTxt">th</span> Bible Workshop</h1>
            <br>
            <h3 style="margin-top: 0px;">Online Registration Click Here</h3>
        </div>

        <div class="col-md-12" id="elsaddai-signin">
            <p class="mpr">
                <b>Note: Please register to access all the documents. If you are already registered, please Sign In.</b>
            </p>
        </div>

        <div class="col-md-12 elsaddai_signin">
            <div class="col-lg-4 col-md-4 col-sm-12">
                <div class="center-img">
                    <a href="https://www.catholictamil.com/" class="text-center" target="_blank">
                        <img class="img-fluid backShadow" src="~/Images/catholicTamilWebsiteAdvertisement.png" />
                    </a>
                </div>
            </div>
            <div class="col-lg-4 col-md-4 col-sm-12">
                <div class="g-wrapper">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="elshadai_signup_wrapper">

                                @using (Html.BeginForm("Index", "Authentication", FormMethod.Post, new { @id = "LoginFormId" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.ValidationSummary(true)
                                    <div class="form-group mg_elshaddai_possub">
                                        <h3 style="color: red">@ViewBag.ErrorMessage</h3>
                                    </div>

                                    <div class="form-group mg_elshaddai_possub">
                                        @Html.TextBoxFor(model => model.Email, new { @class = "form-control mg_form_control", @placeholder = "Email", @Value = "" })
                                        @Html.ValidationMessageFor(model => model.Email)
                                    </div>
                                    <div class="form-group mg_elshaddai_possub">
                                        @Html.PasswordFor(model => model.Password, new { @class = "form-control mg_form_control", @placeholder = "Password", @Value = "" })
                                        @Html.ValidationMessageFor(model => model.Password)
                                    </div>
                                    <div class="mg_elshaddai_create">
                                        <button type="submit" name="button" class="btn btn-primary col-md-12 mtp10px">Sign In</button>
                                    </div>
                                }
                            </div>


                        </div>
                    </div>
                </div>
                @Html.Partial("_UrlView")
            </div>
            <div class="col-lg-4 col-md-4 col-sm-12">
                <div class="center-img">
                    <a href="https://www.unom.ac.in/index.php?route=department/department/deptpage&deptid=19" class="text-center" target="_blank">
                        <img class="img-fluid backShadow" src="~/Images/madrasUniversity.jpg" />
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
