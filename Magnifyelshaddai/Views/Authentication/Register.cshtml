@model Magnifyelshaddai.Models.UserViewModels
@{
    ViewBag.Title = "Registration";
}

@using (Html.BeginForm("Register", "Authentication", FormMethod.Post, new { @id = "registerFormId" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true)
    <div class="container">
        <div class="row">
            <div class="col-md-offset-4 col-md-4">
                <div class="row">
                    <div class="col-md-12">
                        <div class="elshadai_signup_wrapper">
                            <div class="h3 text-center mbt30px">
                                Create An Account
                            </div>
                            <div class="form-group mg_elshaddai_possub">
                                <h3 style="color:red">@ViewBag.ErrorMessage</h3>
                                <h3 style="color:red">@ViewBag.ErrorMessage1</h3>
                            </div>
                            <div class="form-group mg_elshaddai_possub">
                                @Html.TextBoxFor(model => model.Name, new { @class = "form-control mg_form_control", @placeholder = "Name" })
                                @Html.ValidationMessageFor(model => model.Name)
                            </div>
                            <div class="form-group mg_elshaddai_possub">
                                @Html.TextBoxFor(model => model.Mobile, new { @class = "form-control mg_form_control", @placeholder = "Mobile",type = "number",maxlength = 10, minlength = 10 })
                                @Html.ValidationMessageFor(model => model.Mobile)
                            </div>
                            <div class="form-group mg_elshaddai_possub">
                                @Html.TextBoxFor(model => model.Email, new { @class = "form-control mg_form_control", @placeholder = "Email Id" })                               @Html.ValidationMessageFor(model => model.Email)
                            </div>
                            @*<div class="form-group mg_elshaddai_possub">
                                @Html.PasswordFor(model => model.Password, new { @class = "form-control mg_form_control", @placeholder = "Password" })
                                @Html.ValidationMessageFor(model => model.Password)
                            </div>
                            <div class="form-group mg_elshaddai_possub">
                                @Html.PasswordFor(model => model.ComfirmPassword, new { @class = "form-control mg_form_control", @placeholder = "Comfirm Password" })
                                @Html.ValidationMessageFor(model => model.ComfirmPassword)
                            </div>*@
                            <div class="form-group mg_elshaddai_possub">
                                @Html.CheckBoxFor(model => model.IsNotification, new { @class = "IsNotification", @checked = "checked" }) Click for Email Notification
                            </div>
                            <div class="mg_elshaddai_create">
                                <input type="submit" id="btnRegister" value="Create Account" class="btn btn-primary col-md-12 mtp10px" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
@section Scripts
{
    @Scripts.Render("~/bundles/jqueryval")
}