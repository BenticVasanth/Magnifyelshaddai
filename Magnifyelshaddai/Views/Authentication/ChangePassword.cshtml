@model Magnifyelshaddai.Models.PasswordModel

@{
    ViewBag.Title = "ChangePassword";
}

<div class="container">
    <div class="row">
        <div class="col-md-offset-4 col-md-4">
            <div class="row">
                <div class="col-md-12">
                    <div class="elshadai_signup_wrapper">
                        <div class="h3 text-center mbt30px">
                            Change Password to Magnify El-Shaddai
                        </div>
                        @using (Html.BeginForm("ChangePassword", "Authentication", FormMethod.Post, new { @id = "ChangetPasswordFormId" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true)
                            <div class="form-group mg_elshaddai_possub">
                                @if (ViewBag.SuccessMessage != null)
                                {
                                    <h5 class="alert alert-success msg" role="alert">
                                        @ViewBag.SuccessMessage
                                    </h5>
                                }

                                @if (ViewBag.ErrorMessage != null)
                                {
                                    <h5 class="alert alert-danger msg" role="alert">
                                        @ViewBag.ErrorMessage
                                    </h5>
                                    @ViewBag.ErrorMessage1
                                }
@*<p style="color:green;font-weight: bold;">@ViewBag.SuccessMessage</p>
                                <p style="color:red;font-weight: bold;">@ViewBag.ErrorMessage</p>*@
                            </div>
                            <div class="form-group mg_elshaddai_possub">
                                @Html.TextBoxFor(model => model.OldPassword, new { @class = "form-control mg_form_control", type = "password", @placeholder = "Current Password" })
                                @Html.ValidationMessageFor(model => model.OldPassword)
                            </div>
                            <div class="form-group mg_elshaddai_possub">
                                @Html.TextBoxFor(model => model.NewPassword, new { @class = "form-control mg_form_control", type = "password", @placeholder = "New Password" })
                                @Html.ValidationMessageFor(model => model.NewPassword)
                            </div>
                            <div class="form-group mg_elshaddai_possub">
                                @Html.TextBoxFor(model => model.ConfirmPassword, new { @class = "form-control mg_form_control", type = "password", @placeholder = "Confirm Password" })
                                @Html.ValidationMessageFor(model => model.ConfirmPassword)
                            </div>
                            <div class="mg_elshaddai_create">
                                <button type="submit" name="button" class="btn btn-primary col-md-12 mtp10px">Submit</button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

<style>
    .msg {
        text-align: justify !important;
        line-height: 1.5 !important;
    }
</style>

