@model Magnifyelshaddai.Models.LoginViewModels

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row">
        <div class="col-md-offset-4 col-md-4">
            <div class="row">
                <div class="col-md-12">
                    <div class="elshadai_signup_wrapper">
                        <div class="h3 text-center mbt30px">
                            Forgot Password to Magnify El-Shaddai
                        </div>
                        @using (Html.BeginForm("ForgotPassword", "Authentication", FormMethod.Post, new { @id = "ForgotFormId" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true)
                            <div class="form-group mg_elshaddai_possub">
                                <p style="color:green;font-weight: bold;">@ViewBag.SuccessMessage</p>
                                <p style="color:red;font-weight: bold;">@ViewBag.ErrorMessage</p>
                                @ViewBag.ErrorMessage1
                            </div>
                            <div class="form-group mg_elshaddai_possub">
                                @Html.TextBoxFor(model => model.Email, new { @class = "form-control mg_form_control", @placeholder = "Email" })
                                @Html.ValidationMessageFor(model => model.Email)
                            </div>
                            <div class="mg_elshaddai_create">
                                <button type="submit" name="button" class="btn btn-primary col-md-12 mtp10px">Submit</button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
