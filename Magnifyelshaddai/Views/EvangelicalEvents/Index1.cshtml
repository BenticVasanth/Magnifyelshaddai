<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.5.0/js/bootstrap.min.js"></script>
<script src="~/Elshaddai/js/light-box/lc_lightbox.lite.js" type="text/javascript"></script>
<script src="~/Elshaddai/js/light-box/alloy_finger.min.js" type="text/javascript"></script>

<link rel="stylesheet" href="~/Elshaddai/css/light-box/lc_lightbox.css" />
<link rel="stylesheet" href="~/Elshaddai/css/light-box/minimal.css" />

<script>
    $(function () {
        $('.sinai_images_img').hover(function () {
            $(this).children('span').show();
        }, function () {
            $(this).children('span').hide();
        });


        $('.sinai_images_img img').click(function () {
            var img_url = $(this).attr('src');
            var display_popup = '<img src="' + img_url + '" />';
            $('.sinai_images_popup').html(display_popup);
        });

        //live handler
        lc_lightbox('.elem', {
            wrap_class: 'lcl_fade_oc',
            gallery: true,
            txt_toggle_cmd: false,
            thumbs_nav: false,
            download: true,
            skin: 'minimal',
            radius: 0,
            padding: 0,
            border_w: 0,
        });

    });
</script>
