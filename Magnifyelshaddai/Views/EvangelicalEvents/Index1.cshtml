<style>
    .my-0 > a {
        display: block;
        position: relative;
        color: #fff;
        font-size: 15px !important;
        font-weight: 700;
        padding-left: 5px;
        text-decoration: none;
    }

        .my-0 > a .fa-caret-right {
            transform: rotate(0deg);
            transition: .5s;
        }

        .my-0 > a[aria-expanded="true"] .fa-caret-right {
            transform: rotate(90deg);
            transition: .5s;
        }

    #accordion .card.cardBg {
        border: 1px solid #992e93;
        border-radius: 7px;
        margin-bottom: 5px;
    }

    #accordion .card .card-header {
        display: inline-block;
        width: 100%;
        background-color: #992e93;
        padding: 8px 3px;
        border-radius: 5px;
        text-align: left;
    }

    #accordion .card .subCard .card-header {
        display: inline-block;
        width: 100%;
        background-color: #2e4099;
        border-radius: 5px;
        text-align: left;
    }

    #accordion .card .card-body {
        width: 98%;
        margin: 10px auto;
    }

        #accordion .card .card-body .subCard {
            border: 1px solid #2e4099;
            border-radius: 7px;
            margin-bottom: 10px;
        }

            #accordion .card .card-body .subCard .sub-card-body {
                margin: 10px;
            }

    .fa-caret-right {
        margin-right: 10px;
    }

    .galaryImg {
        width: 560px !important;
        padding: 5px !important;
    }

    .elem, .elem * {
        box-sizing: border-box;
        margin: 0 !important;
    }

    .elem {
        display: inline-block;
        font-size: 0;
        width: 100%;
        border-bottom: none;
        background: #fff;
        height: 100%;
    }

        .elem > span {
            cursor: pointer;
            background-size: cover;
            background-position: center center;
            display: inline-block;
            width: 100%;
            height: 100%;
        }

    .lcl_fade_oc.lcl_pre_show #lcl_overlay,
    .lcl_fade_oc.lcl_pre_show #lcl_window,
    .lcl_fade_oc.lcl_is_closing #lcl_overlay,
    .lcl_fade_oc.lcl_is_closing #lcl_window {
        opacity: 0 !important;
    }

    .lcl_fade_oc.lcl_is_closing #lcl_overlay {
        -webkit-transition-delay: .15s !important;
        transition-delay: .15s !important;
    }
</style>


