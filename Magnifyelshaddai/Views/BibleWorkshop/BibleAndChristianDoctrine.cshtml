}

@*Bible and Christian Doctrine - Starts*@
@Html.Partial("_SideMenu")
<div class="container_display tab-pane" id="BibleAndChristianDoctrine">

    <div class="px-4">
        <img class="w-100 my-3" src="~/Images/CourseMaterialsBanner.jpg" />
    </div>

    <div class="tabdisplay">
        <div class="panel-group">
            <div class="panel panel-default">
                <div class="panel-heading textStyle">Diploma in Bible Course Syllabus and Brochure</div>
                <div class="panel-body">
                    <div class="row text-center">
                        <div class="col-md-6 col-sm-3">
