@model IEnumerable<Magnifyelshaddai.Models.EDMXModel.SinaiLetter>

@{
    ViewBag.Title = "Magnify ElShaddai - Sinai Letters";
}

@*<link href="~/Content/Site.css" rel="stylesheet" />*@

@Html.Partial("_SideMenu")

<div class="container_display sinai_letter">
    <div class="sinai_letters">
        <div class="sinai-header">
            <div class="sinai-banner"></div>
            <img src="~/Images/Sinai_Letters_Logo.png" alt="Sinai Letters logo" class="sinai-letters-img" />
            @if (Session["UserType"].ToString() == "Admin" || Session["UserType"].ToString() == "SuperUser")
            {
                    <a href="@Url.Action("UploadSinaiLetter", "SinaiLetter")">
                        <span class="btn addSinai">Add new</span>
                    </a>
            }
        </div>

        <div class="sinai_images_popup"></div>
        <div class="sinai_images">
            @foreach (var sinaiLetter in ViewBag.SinaiLetters)
            {
                <div class="sinai_images_img">
                    <a class="elem" href="@sinaiLetter.FilePath" data-lcl-thumb="@sinaiLetter.FilePath">
                        <span style="background-image: url(@sinaiLetter.FilePath);"></span>
                    </a>
                    <span style="display: none;"> <a href="@sinaiLetter.FilePath" target="_blank" download> <img src="~/Images/download.png" onclick="insertDownloadDetails(@sinaiLetter.Id)" /> </a> </span>*
                    <span style="display: none;"> <a href="@sinaiLetter.FilePath" target="_blank" download> <i style="font-size:25px; color:white;" onclick="insertDownloadDetails(@sinaiLetter.Id)" class="fa fa-download" aria-hidden="true"></i> </a> </span>
                </div>
            }
        </div>

    </div>
</div>


<style type="text/css">
    .elem, .elem * {
        box-sizing: border-box;
        margin: 0 !important;
    }

    .elem {
        display: inline-block;
        font-size: 0;
        width: 100%;
        border-bottom: none;
        background: #fff;
        height: 100%;
    }

        .elem > span {
            cursor: pointer;
            background-size: cover;
            background-position: center center;
            display: inline-block;
            width: 100%;
            height: 100%;
        }

    .lcl_fade_oc.lcl_pre_show #lcl_overlay,
    .lcl_fade_oc.lcl_pre_show #lcl_window,
    .lcl_fade_oc.lcl_is_closing #lcl_overlay,
    .lcl_fade_oc.lcl_is_closing #lcl_window {
        opacity: 0 !important;
    }

    .lcl_fade_oc.lcl_is_closing #lcl_overlay {
        -webkit-transition-delay: .15s !important;
        transition-delay: .15s !important;
    }
</style>

<script src="~/Elshaddai/js/light-box/jquery.js" type="text/javascript"></script>
<script src="~/Elshaddai/js/light-box/lc_lightbox.lite.js" type="text/javascript"></script>
<script src="~/Elshaddai/js/light-box/alloy_finger.min.js" type="text/javascript"></script>

<link rel="stylesheet" href="~/Elshaddai/css/light-box/lc_lightbox.css" />
<link rel="stylesheet" href="~/Elshaddai/css/light-box/minimal.css" />


<script type="text/javascript">
    function insertDownloadDetails(SinaiLetterId) {
        var url = "/SinaiLetter/DownloadSinaiLetter/";
        $.ajax({
            type: 'GET',
            url: url,
            data: { id: SinaiLetterId },

            success: function (evt) {
                //alert('Downloaded Successfully');
                //location.reload();
            },
            error: function (XMLHttpRequest, downloadStatus, errorThrown) {
                //alert('Download unsuccessful : ' + downloadStatus + ' ' + errorThrown);
            }
        });
    }

    $(function () {
        $('.sinai_images_img').hover(function () {
            $(this).children('span').show();
        }, function () {
            $(this).children('span').hide();
        });


        $('.sinai_images_img img').click(function () {
            var img_url = $(this).attr('src');
            var display_popup = '<img src="' + img_url + '" />';
            $('.sinai_images_popup').html(display_popup);
        });

        //live handler
        lc_lightbox('.elem', {
            wrap_class: 'lcl_fade_oc',
            gallery: true,
            txt_toggle_cmd: false,
            thumbs_nav: false,
            download: true,
            skin: 'minimal',
            radius: 0,
            padding: 0,
            border_w: 0,
        });

    });
</script>
